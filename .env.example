# Desenvolvimento Local (banco Docker local):
# Parâmetros otimizados para desenvolvimento local
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/aupus_local?schema=public&connection_limit=10&pool_timeout=20"

PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=aupus-super-secret-key-change-in-production-2025
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# MQTT Configuration
MQTT_HOST=72.60.158.163
MQTT_PORT=1883
MQTT_USERNAME=root
MQTT_PASSWORD=your_password

# MQTT Mode: production | development | disabled
# - production: Conecta ao broker e salva dados no banco
# - development: Conecta ao broker mas NÃO salva dados (apenas logs/WebSocket)
# - disabled: NÃO conecta ao broker (desabilita MQTT completamente)
MQTT_MODE=production
INSTANCE_ID=nexon-local-dev

# MQTT Logging: minimal | normal | verbose
# - minimal: Apenas erros críticos
# - normal: Conexão, erros e estatísticas importantes
# - verbose: Todos os logs (debug completo)
MQTT_LOG_LEVEL=normal

# Sentry Configuration
SENTRY_DSN="https://92a540132941fa92bde316ead7e537e2@o4510981695537152.ingest.us.sentry.io/4510981705367552"

# Redis Configuration (Buffer MQTT) - Docker local
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# === EMAIL (SMTP) - Hostinger ===
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply-aupus@aupusenergia.com.br
SMTP_PASS="#Aupus2024#"
SMTP_FROM_NAME=Aupus
SMTP_FROM_EMAIL=no-reply-aupus@aupusenergia.com.br